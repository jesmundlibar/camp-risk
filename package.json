{
  "name": "camp-risk",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && npx --yes serve public -p 5173 -s",
    "build": "npm run build:css",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles/app.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles/app.css --watch"
  },
  "dependencies": {
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.1.12",
    "serve": "14.2.4",
    "tailwindcss": "4.1.12"
  }
}
