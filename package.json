{
  "name": "camp-risk",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:spa": "vite --port 5173",
    "dev": "npm run dev:spa",
    "dev:static": "npm run build:css && npx --yes serve public -p 5173 -s",
    "build": "npm run build:css",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles/app.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles/app.css --watch"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.1.12",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "serve": "14.2.4",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.7",
    "vite": "^6.4.2"
  }
}
