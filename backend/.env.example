# Copy to .env or local.env in this folder (both gitignored). Optional Google Sheets backup / admin link.
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_BACKUP_ENABLED=1
#
# Share the sheet with the service account (Editor), then set ONE of:
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=<base64 of the entire JSON key file>
# GOOGLE_SERVICE_ACCOUNT_FILE=C:\path\to\service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
#
# One-time backfill of existing assessments (duplicates rows if run twice):
#   python manage.py backfill_google_sheets_assessed
